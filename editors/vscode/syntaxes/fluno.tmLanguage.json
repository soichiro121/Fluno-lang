{
    "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
    "name": "Fluno",
    "patterns": [
        {
            "include": "#comments"
        },
        {
            "include": "#strings"
        },
        {
            "include": "#keywords"
        },
        {
            "include": "#types"
        },
        {
            "include": "#numbers"
        },
        {
            "include": "#operators"
        },
        {
            "include": "#functions"
        },
        {
            "include": "#variables"
        }
    ],
    "repository": {
        "comments": {
            "patterns": [
                {
                    "name": "comment.line.double-slash.fluno",
                    "match": "//.*$"
                },
                {
                    "name": "comment.block.fluno",
                    "begin": "/\\*",
                    "end": "\\*/"
                }
            ]
        },
        "strings": {
            "patterns": [
                {
                    "name": "string.quoted.double.fluno",
                    "begin": "\"",
                    "end": "\"",
                    "patterns": [
                        {
                            "name": "constant.character.escape.fluno",
                            "match": "\\\\."
                        }
                    ]
                },
                {
                    "name": "string.quoted.single.fluno",
                    "begin": "'",
                    "end": "'"
                }
            ]
        },
        "keywords": {
            "patterns": [
                {
                    "name": "keyword.control.fluno",
                    "match": "\\b(if|else|match|while|for|loop|break|continue|return|in)\\b"
                },
                {
                    "name": "keyword.other.fluno",
                    "match": "\\b(fn|let|mut|struct|enum|impl|trait|type|mod|use|import|pub|async|await|where|self|Self)\\b"
                },
                {
                    "name": "constant.language.fluno",
                    "match": "\\b(true|false|None|Some|Ok|Err)\\b"
                }
            ]
        },
        "types": {
            "patterns": [
                {
                    "name": "storage.type.fluno",
                    "match": "\\b(Int|Float|Bool|String|Char|Option|Result|Vec|Array|Tensor|Gaussian|Uniform|Bernoulli|Beta)\\b"
                },
                {
                    "name": "entity.name.type.fluno",
                    "match": "\\b[A-Z][a-zA-Z0-9_]*\\b"
                }
            ]
        },
        "numbers": {
            "patterns": [
                {
                    "name": "constant.numeric.float.fluno",
                    "match": "\\b[0-9]+\\.[0-9]+\\b"
                },
                {
                    "name": "constant.numeric.integer.fluno",
                    "match": "\\b[0-9]+\\b"
                }
            ]
        },
        "operators": {
            "patterns": [
                {
                    "name": "keyword.operator.fluno",
                    "match": "(->|=>|\\+|-|\\*|/|%|==|!=|<=|>=|<|>|&&|\\|\\||!|=|\\+=|-=|\\*=|/=)"
                }
            ]
        },
        "functions": {
            "patterns": [
                {
                    "name": "entity.name.function.fluno",
                    "match": "\\b([a-z_][a-zA-Z0-9_]*)\\s*(?=\\()"
                }
            ]
        },
        "variables": {
            "patterns": [
                {
                    "name": "variable.other.fluno",
                    "match": "\\b[a-z_][a-zA-Z0-9_]*\\b"
                }
            ]
        }
    },
    "scopeName": "source.fluno"
}