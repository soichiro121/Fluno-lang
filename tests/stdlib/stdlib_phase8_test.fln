fn main() {
    println("Starting Phase 8 Test...");

    // 1. Math
    let pi = 3.1415926535;
    // sin(PI/2) should be 1.0 (approx)
    let s = sin(pi / 2.0);
    println("sin(pi/2) = " + s);
    if (s - 1.0).abs() < 0.0001 { println("PASS: sin"); } else { println("FAIL: sin"); }

    let c = cos(0.0);
    println("cos(0) = " + c);
    if (c - 1.0).abs() < 0.0001 { println("PASS: cos"); } else { println("FAIL: cos"); }

    let l = ln(exp(2.0));
    println("ln(exp(2)) = " + l);
    if (l - 2.0).abs() < 0.0001 { println("PASS: ln/exp"); } else { println("FAIL: ln/exp"); }
    
    let p = pow(2.0, 3.0);
    println("pow(2, 3) = " + p);
    if (p - 8.0).abs() < 0.0001 { println("PASS: pow"); } else { println("FAIL: pow"); }

    // 2. Serialize
    // Since Map literal syntax might not be fully supported as { k: v }, use JSON string parsing test.
    let json_in = "{\"name\": \"Flux\", \"version\": 1, \"features\": [\"AD\", \"Probabilistic\", \"FFI\"]}";
    println("Input JSON: " + json_in);
    
    let parsed = from_json(json_in);
    // parsed is expected to be a Map/Struct
    
    let json_out = to_json(parsed);
    println("Output JSON: " + json_out);

    if json_out.contains("Flux") {
        println("PASS: to_json/from_json roundtrip");
    } else {
        println("FAIL: to_json/from_json roundtrip");
    }
}
