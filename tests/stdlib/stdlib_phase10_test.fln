#[link(name = "fluno_rt.dll")]
extern "C" {
    fn fluno_plot_chart(json: String, path: String) -> Int;
}

struct Quaternion {
    w: Float,
    x: Float,
    y: Float,
    z: Float,
}

fn quat_mul(q1: Quaternion, q2: Quaternion) -> Quaternion {
    let w1 = q1.w; let x1 = q1.x; let y1 = q1.y; let z1 = q1.z;
    let w2 = q2.w; let x2 = q2.x; let y2 = q2.y; let z2 = q2.z;
    
    let w = w1*w2 - x1*x2 - y1*y2 - z1*z2;
    let x = w1*x2 + x1*w2 + y1*z2 - z1*y2;
    let y = w1*y2 - x1*z2 + y1*w2 + z1*x2;
    let z = w1*z2 + x1*y2 - y1*x2 + z1*w2;
    
    Quaternion { w: w, x: x, y: y, z: z }
}

struct PID {
    kp: Float,
    ki: Float,
    kd: Float,
    integral: Float,
    prev_error: Float,
}

struct PIDResult {
    output: Float,
    new_pid: PID,
}

fn pid_update(pid: PID, setpoint: Float, measured: Float, dt: Float) -> PIDResult {
    let error = setpoint - measured;
    let integral = pid.integral + error * dt;
    let prev_err = pid.prev_error;
    let derivative = (error - prev_err) / dt;
    
    let output = pid.kp * error + pid.ki * integral + pid.kd * derivative;
    
    let new_pid = PID {
        kp: pid.kp,
        ki: pid.ki,
        kd: pid.kd,
        integral: integral,
        prev_error: error,
    };
    
    PIDResult { output: output, new_pid: new_pid }
}

fn main() {
    println("Starting Phase 10 Test (Robotics & Plotting)...");

    println("Testing Quaternion...");
    let q1 = Quaternion { w: 1.0, x: 0.0, y: 0.0, z: 0.0 };
    let q2 = Quaternion { w: 0.0, x: 1.0, y: 0.0, z: 0.0 };
    let q3 = quat_mul(q1, q2);
    
    println("q3.x = " + q3.x);
    if q3.w == 0.0 && q3.x == 1.0 {
        println("PASS: Quaternion Multiply");
    } else {
        println("FAIL: Quaternion Multiply");
    }

    println("Testing PID Loop...");
    let mut pid = PID {
        kp: 2.0,
        ki: 0.1,
        kd: 0.1,
        integral: 0.0,
        prev_error: 0.0,
    };
    let target = 10.0;
    let mut current = 0.0;
    let dt = 0.1;
    
    let mut pos_data = [];
    
    let mut t = 0.0;
    while t < 5.0 {
        let res = pid_update(pid, target, current, dt);
        let control = res.output;
        pid = res.new_pid;
        
        current = current + control * dt;
        
        pos_data = pos_data.push([t, current]);
        
        t = t + dt;
    }
    
    println("Final Position: " + current);
    if (current - target).abs() < 0.5 {
        println("PASS: PID Control Reached Target");
    } else {
        println("FAIL: PID Control Did Not Converge");
    }

    println("Testing Plotting...");
    
    let data_json = to_json(pos_data);
    
    let s1_json = "{\"label\": \"Position\", \"color\": \"blue\", \"data\": " + data_json + "}";
    let series_json = "[" + s1_json + "]";
    let chart_json = "{\"title\": \"PID Control Response\", \"x_label\": \"Time (s)\", \"y_label\": \"Position\", \"series\": " + series_json + "}";
    
    println("JSON built. Length: " + chart_json.len());
    
    let res = fluno_plot_chart(chart_json, "pid_plot.png");
    if res == 0 {
        println("PASS: Plot chart successful (saved to pid_plot.png)");
    } else {
        println("FAIL: Plot chart failed");
    }
}
