
fn main() {
    let mu = 0.0;
    let kappa = 1.0;
    let vm = VonMises(mu, kappa);
    
    let x = sample(vm);
    print("Sampled from VonMises(0, 1): ");
    println(to_json(x));

    let p = vm.log_pdf(x);
    print("Log PDF at sample: ");
    println(to_json(p));

    // Test a simpler case
    let vm2 = VonMises(3.14159, 2.0);
    let x2 = sample(vm2);
    print("Sampled from VonMises(PI, 2): ");
    println(to_json(x2));
}
