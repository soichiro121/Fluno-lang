struct Point {
    x: Int,
    y: Int,
}

impl Point {
    fn new(x: Int, y: Int) -> Point {
        Point { x: x, y: y }
    }

    fn sum(self) -> Int {
        self.x + self.y
    }
}

fn main() {
    let p = Point::new(10, 20);
    print(p.x);
    print(p.y);
    print(p.sum());


    let p2 = Point::new(3, 4);
    print(p2.sum());
}

