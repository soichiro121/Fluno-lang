
struct Point {
    x: Int,
    y: Int
}

impl Point {
    fn dist2(self) -> Int {
        self.x * self.x + self.y * self.y
    }
    
    fn add(self, other: Point) -> Point {
        Point { x: self.x + other.x, y: self.y + other.y }
    }
}

fn main() {
    let p1 = Point { x: 3, y: 4 };
    let d = p1.dist2();
    print(d); 
    
    let p2 = Point { x: 1, y: 1 };
    let p3 = p1.add(p2);
    print(p3.x); 
    print(p3.y); 
}
