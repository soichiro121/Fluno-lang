// tests/test_ad.fln
// AD (自動微分) 機能のテスト

fn test_basic_ops() {
    println("Testing basic AD operations...");
    
    let x = 3.0;
    let y = x * x;  // y = x^2, dy/dx = 2x = 6
    
    println("x = 3.0, x^2 = ");
    println(y);
}

fn test_tanh() {
    println("Testing tanh...");
    // tanh(0) = 0, tanh(1) ≈ 0.76
    let x = 1.0;
    // VMにtanhが露出されていない可能性があるので、後で確認
}

fn main() {
    test_basic_ops();
    println("AD tests completed.");
}
